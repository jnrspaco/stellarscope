# Server: Stellar address that receives USDC payments
PAY_TO=G...YOUR_STELLAR_PUBLIC_KEY...

# Client/MCP: Secret key for the wallet that pays for queries
STELLAR_PRIVATE_KEY=S...YOUR_SECRET_KEY...

# Optional
STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
FACILITATOR_URL=https://www.x402.org/facilitator
STELLARSCOPE_URL=http://localhost:3402
PORT=3402
